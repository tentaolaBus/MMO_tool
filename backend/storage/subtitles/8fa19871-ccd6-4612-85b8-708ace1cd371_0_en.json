  "segments": [
    {
      "start": 0,
      "end": 5,
      "text": "What's stopping you? Are you too tired?"
    },
    {
      "start": 5,
      "end": 7,
      "text": "Didn't good enough sleep?"
    },
    {
      "start": 7,
      "end": 10,
      "text": "Don't have enough energy?"
    },
    {
      "start": 10,
      "end": 13,
      "text": "Don't have enough time? Is that what's stopping you right now?"
    },
    {
      "start": 13,
      "end": 15,
      "text": "Don't have enough money?"
    },
    {
      "start": 15,
      "end": 18,
      "text": "Is that the thing?"
    },
    {
      "start": 18,
      "end": 22,
      "text": "Or is it the thing that's stopping you?"
    },
    {
      "start": 22,
      "end": 24,
      "text": "You."
    },
    {
      "start": 25,
      "end": 31,
      "text": "Excuse us sound best to the person that's making the mug."
    },
    {
      "start": 31,
      "end": 34,
      "text": "Stop filing sorry for yourself."
    },
    {
      "start": 34,
      "end": 36,
      "text": "Get off the pity party."
    },
    {
      "start": 36,
      "end": 44,
      "text": "Telling everybody your sad and soft stories trying to get people to show up to your pity parties and your pity parades."
    },
    {
      "start": 44,
      "end": 53,
      "text": "If you ever see me in a rose voice, a six or seven star hotel living my life to the fullest, don't get jealous of me."
    },
    {
      "start": 53,
      "end": 56,
      "text": "Because I work my ass off to get it."
    },
    {
      "start": 56,
      "end": 60,
      "text": "Nobody handed me nothing."
    }
  ],
