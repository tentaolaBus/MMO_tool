  "segments": [
    {
      "id": 0,
      "start": 0.0,
      "end": 2.0,
      "text": "Hey, Dan, what you got there?"
    },
    {
      "id": 1,
      "start": 2.0,
      "end": 4.0,
      "text": "Birthday present for Uncle Arrow."
    },
    {
      "id": 2,
      "start": 4.0,
      "end": 6.0,
      "text": "Cool, can I see?"
    },
    {
      "id": 3,
      "start": 6.0,
      "end": 7.0,
      "text": "Son, don't open it."
    },
    {
      "id": 4,
      "start": 7.0,
      "end": 8.0,
      "text": "Don't open it?"
    },
    {
      "id": 5,
      "start": 8.0,
      "end": 10.0,
      "text": "Two, one."
    },
    {
      "id": 6,
      "start": 10.0,
      "end": 14.0,
      "text": "What is wrong with you?"
    },
    {
      "id": 7,
      "start": 14.0,
      "end": 16.0,
      "text": "I'm sorry, son."
    },
    {
      "id": 8,
      "start": 16.0,
      "end": 18.0,
      "text": "I told you not to open it."
    },
    {
      "id": 9,
      "start": 18.0,
      "end": 20.0,
      "text": "You know how you're Uncle Arrow?"
    },
    {
      "id": 10,
      "start": 20.0,
      "end": 22.0,
      "text": "I'm sorry, son."
    },
    {
      "id": 11,
      "start": 22.0,
      "end": 24.0,
      "text": "I told you not to open it."
    },
    {
      "id": 12,
      "start": 24.0,
      "end": 26.0,
      "text": "You know how you're Uncle Arrow?"
    },
    {
      "id": 13,
      "start": 26.0,
      "end": 28.0,
      "text": "I'm sorry, son."
    },
    {
      "id": 14,
      "start": 28.0,
      "end": 32.0,
      "text": "You know how you're Uncle Arrow always sends me a prank for my birthday?"
    },
    {
      "id": 15,
      "start": 32.0,
      "end": 35.0,
      "text": "Well, that year I decided it was time for a little vacuum pack."
    },
    {
      "id": 16,
      "start": 35.0,
      "end": 37.0,
      "text": "Hey, back."
    },
    {
      "id": 17,
      "start": 37.0,
      "end": 38.0,
      "text": "Cool, can I get in on it?"
    },
    {
      "id": 18,
      "start": 38.0,
      "end": 41.0,
      "text": "Oh, son, no offense, but this game's for big boys."
    },
    {
      "id": 19,
      "start": 41.0,
      "end": 44.0,
      "text": "You're Uncle Arrow's one of the all-time great pranksters."
    },
    {
      "id": 20,
      "start": 44.0,
      "end": 45.0,
      "text": "No."
    },
    {
      "id": 21,
      "start": 45.0,
      "end": 47.0,
      "text": "I think you should just stay out of it."
    },
    {
      "id": 22,
      "start": 47.0,
      "end": 48.0,
      "text": "I wouldn't want you to get hurt."
    },
    {
      "id": 23,
      "start": 48.0,
      "end": 52.0,
      "text": "Are you saying you don't think I have what it takes to put one over on Uncle Arrow?"
    },
    {
      "id": 24,
      "start": 52.0,
      "end": 55.0,
      "text": "Son, you couldn't even put one over on your old man."
    },
    {
      "id": 25,
      "start": 56.0,
      "end": 59.0,
      "text": "Jay, Dad, I guess you're right."
    },
    {
      "id": 26,
      "start": 59.0,
      "end": 61.0,
      "text": "We'll see you later."
    },
    {
      "id": 27,
      "start": 61.0,
      "end": 63.0,
      "text": "Jackson, I know that look."
    },
    {
      "id": 28,
      "start": 63.0,
      "end": 65.0,
      "text": "What look?"
    },
    {
      "id": 29,
      "start": 65.0,
      "end": 67.0,
      "text": "My?"
    },
    {
      "id": 30,
      "start": 70.0,
      "end": 72.0,
      "text": "Someone tells me this ain't gonna be pretty."
    },
    {
      "id": 31,
      "start": 72.0,
      "end": 75.0,
      "text": "But it might be fun."
    },
    {
      "id": 32,
      "start": 79.0,
      "end": 84.0,
      "text": "Darling, in three and a half miles, you are all mine."
    },
    {
      "id": 33,
      "start": 84.0,
      "end": 87.0,
      "text": "Maybe just three."
    },
    {
      "id": 34,
      "start": 88.0,
      "end": 90.0,
      "text": "What the heck?"
    },
    {
      "id": 35,
      "start": 90.0,
      "end": 95.0,
      "text": "How about I just jog down in the driveway, get the mail and be right back?"
    },
    {
      "id": 36,
      "start": 98.0,
      "end": 100.0,
      "text": "Come to Papa."
    },
    {
      "id": 37,
      "start": 100.0,
      "end": 102.0,
      "text": "Booyah!"
    },
    {
      "id": 38,
      "start": 102.0,
      "end": 105.0,
      "text": "Boy, I did use a glass of milk."
    },
    {
      "id": 39,
      "start": 105.0,
      "end": 109.0,
      "text": "You lost, but get real interesting, son."
    },
    {
      "id": 40,
      "start": 114.0,
      "end": 116.0,
      "text": "Morning, son."
    },
    {
      "id": 41,
      "start": 116.0,
      "end": 118.0,
      "text": "I'm sure our heavy sleeper."
    },
    {
      "id": 42,
      "start": 118.0,
      "end": 121.0,
      "text": "Well, I'm gonna get you for this."
    },
    {
      "id": 43,
      "start": 121.0,
      "end": 144.0,
      "text": "What's wrong, Dad?"
    },
    {
      "id": 44,
      "start": 144.0,
      "end": 146.0,
      "text": "You look a little down."
    },
    {
      "id": 45,
      "start": 146.0,
      "end": 148.0,
      "text": "Good job, son."
    },
    {
      "id": 46,
      "start": 149.0,
      "end": 153.0,
      "text": "Now, let me give you a little hug, okay?"
    },
    {
      "id": 47,
      "start": 153.0,
      "end": 155.0,
      "text": "Oh, no, you stay away from me, sticky man."
    },
    {
      "id": 48,
      "start": 155.0,
      "end": 159.0,
      "text": "Oh, no, let me give you a little low fat, raspberry, love."
    },
    {
      "id": 49,
      "start": 159.0,
      "end": 161.0,
      "text": "Good boy."
    },
    {
      "id": 50,
      "start": 161.0,
      "end": 166.0,
      "text": "Before digital photography, that would've taken me a week to paint."
    },
    {
      "id": 51,
      "start": 166.0,
      "end": 169.0,
      "text": "Got to love the progress."
    },
    {
      "id": 52,
      "start": 173.0,
      "end": 175.0,
      "text": "That was a good one, Dad."
    },
    {
      "id": 53,
      "start": 175.0,
      "end": 177.0,
      "text": "That was a good one."
    },
    {
      "id": 54,
      "start": 177.0,
      "end": 179.0,
      "text": "That could be a hug."
    },
    {
      "id": 55,
      "start": 179.0,
      "end": 180.0,
      "text": "Oh, no."
    },
    {
      "id": 56,
      "start": 180.0,
      "end": 183.0,
      "text": "Get away from me, pudding boy."
    },
    {
      "id": 57,
      "start": 183.0,
      "end": 185.0,
      "text": "Get away from me."
    },
    {
      "id": 58,
      "start": 185.0,
      "end": 188.0,
      "text": "Get away from me!"
    },
    {
      "id": 59,
      "start": 188.0,
      "end": 190.0,
      "text": "Get away from me!"
    },
    {
      "id": 60,
      "start": 190.0,
      "end": 193.0,
      "text": "Get away!"
    },
    {
      "id": 61,
      "start": 201.0,
      "end": 204.0,
      "text": "Hey, Jackson, get up, give me a soda, would you?"
    },
    {
      "id": 62,
      "start": 204.0,
      "end": 209.44,
      "text": "Yeah, sure. I go open the refrigerator and a monkey pops out and hits me over the head with a banana."
    },
    {
      "id": 63,
      "start": 211.2,
      "end": 218.88,
      "text": "You want to drink you go get it. Oh, no. I see what you're doing. Turn around so I get up and open up the fridge and a monkey hits me in the face with a pie."
    },
    {
      "id": 64,
      "start": 220.8,
      "end": 222.8,
      "text": "So there is a monkey!"
    },
    {
      "id": 65,
      "start": 228.32,
      "end": 233.64,
      "text": "Oh, no, man. I'm not getting it. Neither am I. Let the monkey get it."
    },
    {
      "id": 66,
      "start": 234.0,
      "end": 242.0,
      "text": "Well, maybe there's a $10 million winner at the next house. Come on, guys!"
